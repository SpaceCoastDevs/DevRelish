---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ImportMeetupForm from '../../../components/meetups/ImportMeetupForm';
import { db, Groups } from 'astro:db';
import { eq } from 'astro:db';

if (!Astro.locals.user) return Astro.redirect('/login');
const user = Astro.locals.user;

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect('/dashboard');
---

<DashboardLayout title="Import from Meetup">
  <div class="page-header">
    <a href="/dashboard/gatherings" class="back-link">← Back to gatherings</a>
    <h1>Import from Meetup</h1>
    <p class="page-subtitle">
      Import upcoming events from a Meetup.com group directly into <strong
        >{group.name}</strong
      >.
    </p>
  </div>

  <div class="import-wrap">
    <ImportMeetupForm client:load />

    <div class="import-notice">
      <strong>Only import your own events.</strong> This tool is intended for organizers
      transitioning their group's existing Meetup.com events to DevRel(ish) — please
      don't import events from groups you don't run.
    </div>
  </div>
</DashboardLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .back-link {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }
  .back-link:hover {
    color: var(--color-primary);
  }

  h1 {
    font-size: var(--size-3xl);
    margin-bottom: 0.375rem;
  }

  .page-subtitle {
    font-size: var(--size-base);
    color: var(--color-text-muted);
    max-width: none;
  }

  .import-wrap {
    max-width: 640px;
  }

  /* ── ImportMeetupForm styles ── */
  :global(.imf-wrap) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.imf-intro) {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    max-width: none;
    margin: 0;
  }

  :global(.imf-url-form) {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  :global(.imf-event-list) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.imf-event-card) {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.imf-event-card.is-selected) {
    border-color: var(--color-primary);
  }

  :global(.imf-event-toggle) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    cursor: pointer;
    user-select: none;
  }
  :global(.imf-event-toggle input[type='checkbox']) {
    width: 16px;
    height: 16px;
    accent-color: var(--color-primary);
    cursor: pointer;
    flex-shrink: 0;
  }
  :global(.imf-event-toggle-label) {
    font-weight: 700;
    font-size: var(--size-sm);
  }

  :global(.imf-event-fields) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--color-border);
  }

  :global(.imf-missing-label) {
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    padding-bottom: 0.375rem;
    border-bottom: 1px dashed var(--color-border);
  }

  :global(.imf-truncated-notice) {
    color: #b45309 !important;
    font-weight: 600;
  }

  .import-notice {
    font-size: var(--size-sm);
    color: #92400e;
    background: #fffbeb;
    border: 1.5px solid #fde68a;
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    margin-top: 1.5rem;
    line-height: 1.6;
  }

  :global(.imf-autofilled) {
    color: #166534 !important;
    font-weight: 600;
  }

  :global(.imf-capacity) {
    max-width: 140px;
  }

  :global(.imf-submit-row) {
    display: flex;
    gap: 0.875rem;
    align-items: center;
    margin-top: 0.5rem;
  }

  :global(.imf-results) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.imf-error-list) {
    margin: 0.5rem 0 0 1rem;
    font-weight: 400;
    font-size: var(--size-sm);
  }

  :global(.alert-success) {
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    font-size: var(--size-sm);
    font-weight: 600;
  }

  :global(.form-actions) {
    display: flex;
    gap: 0.875rem;
    align-items: center;
  }
</style>
