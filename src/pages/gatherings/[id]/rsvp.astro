---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db, Meetups, RSVPs, Groups, GatheringSpeakers, GatheringSessions, GatheringSessionSpeakers, count, eq, and } from "devrelish:db";
import { asc, inArray } from "devrelish:db";
import { absoluteUrl, formatDate, formatTime, spotsLeft, generateId, googleCalendarUrl, osmUrl, groupUrl, withBase } from "../../../lib/utils";
import { renderMarkdown } from "../../../lib/markdown";

const { id } = Astro.params;

if (!id) return Astro.redirect(withBase("/groups"));

const [meetup] = await db.select().from(Meetups).where(eq(Meetups.id, id));
if (!meetup) return Astro.redirect(withBase("/groups"));

const [group] = await db.select().from(Groups).where(eq(Groups.id, meetup.groupId));
if (!group || (group.status !== "approved" && group.status !== "closed")) {
  return Astro.redirect(withBase("/groups"));
}

const isGroupClosed = group.status === "closed";
const isMeetupCanceled = meetup.status === "canceled";
const isPast = meetup.date < new Date();

type FormResult =
  | { type: "success"; name: string; email: string; cancelToken: string }
  | { type: "duplicate"; email: string }
  | { type: "full" }
  | { type: "error"; message: string };

let result: FormResult | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  // Bot protection: honeypot field must be empty
  const hp = form.get("_hp")?.toString() ?? "";
  // Bot protection: form must have been open for at least 3 seconds
  const submittedAt = parseInt(form.get("_t")?.toString() ?? "0", 10);
  const elapsed = Date.now() - submittedAt;
  if (hp || elapsed < 3000) {
    // Silently fake success so bots don't know they were blocked
    result = { type: "success", name: form.get("name")?.toString().trim() ?? "", email: form.get("email")?.toString().trim().toLowerCase() ?? "", cancelToken: "" };
  } else {
    const name = form.get("name")?.toString().trim() ?? "";
    const email = form.get("email")?.toString().trim().toLowerCase() ?? "";
    const jobTitle = form.get("jobTitle")?.toString().trim() ?? "";
    const company = form.get("company")?.toString().trim() ?? "";

    if (!name || !email || !jobTitle || !company) {
      result = { type: "error", message: "All fields are required." };
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      result = { type: "error", message: "Please enter a valid email address." };
    } else if (isGroupClosed) {
      result = { type: "error", message: "This group is no longer accepting RSVPs." };
    } else if (isMeetupCanceled) {
      result = { type: "error", message: "This gathering has been cancelled." };
    } else if (meetup.date < new Date()) {
      result = { type: "error", message: "This gathering has already passed." };
    } else {
      // Re-fetch fresh RSVP count inside the POST handler
      const [countResult] = await db
        .select({ val: count() })
        .from(RSVPs)
        .where(eq(RSVPs.meetupId, id));
      const currentCount = countResult?.val ?? 0;

      if (currentCount >= meetup.capacity) {
        result = { type: "full" };
      } else {
        // Check for duplicate
        const [duplicate] = await db
          .select()
          .from(RSVPs)
          .where(and(eq(RSVPs.meetupId, id), eq(RSVPs.email, email)));

        if (duplicate) {
          result = { type: "duplicate", email };
        } else {
          const cancelToken = generateId();
          await db.insert(RSVPs).values({
            id: generateId(),
            meetupId: id,
            name,
            email,
            jobTitle,
            company,
            cancelToken,
            createdAt: new Date(),
          });
          result = { type: "success", name, email, cancelToken };
        }
      }
    }
  }
}

// Bluesky share intent
const bskyShareUrl = (() => {
  const eventUrl = absoluteUrl(Astro.url.origin, `/gatherings/${id}/rsvp`);
  const withHandle = group.blueskyHandle
    ? ` with @${group.blueskyHandle.replace(/^@/, "")}`
    : "";
  const hashtags = group.tags
    ? group.tags
        .split(",")
        .map((t) => `#${t.trim().replace(/\s+/g, "")}`)
        .filter(Boolean)
        .slice(0, 2)
        .join(" ")
    : "";
  const tagPart = hashtags ? ` ${hashtags}` : "";
  const text = `I'm heading to ${meetup.title}${withHandle} — come join us!${tagPart}\n${eventUrl}`;
  return `https://bsky.app/intent/compose?text=${encodeURIComponent(text)}`;
})();

// Calendar links (built once; used in success state)
const gcalUrl = googleCalendarUrl({
  title: meetup.title,
  date: meetup.date,
  time: meetup.time,
  venue: meetup.venue,
  address: meetup.address,
  description: `${meetup.description}\n\nHosted by ${group.name}`,
});
const icsUrl = withBase(`/api/calendar/${id}`);

// Fetch speakers and sessions independently
const speakers = await db
  .select()
  .from(GatheringSpeakers)
  .where(eq(GatheringSpeakers.gatheringId, id))
  .orderBy(asc(GatheringSpeakers.sortOrder), asc(GatheringSpeakers.createdAt));

const sessionsRaw = await db
  .select()
  .from(GatheringSessions)
  .where(eq(GatheringSessions.gatheringId, id))
  .orderBy(asc(GatheringSessions.sortOrder), asc(GatheringSessions.createdAt));

const sessionIds = sessionsRaw.map((s) => s.id);
const sessionSpeakerRows = sessionIds.length > 0
  ? await db.select().from(GatheringSessionSpeakers).where(inArray(GatheringSessionSpeakers.sessionId, sessionIds))
  : [];

const sessions = sessionsRaw.map((s) => ({
  ...s,
  speakers: sessionSpeakerRows
    .filter((ss) => ss.sessionId === s.id)
    .sort((a, b) => a.sortOrder - b.sortOrder)
    .map((ss) => speakers.find((sp) => sp.id === ss.speakerId))
    .filter(Boolean),
}));

// Fetch current RSVP count for display
const [rsvpResult] = await db
  .select({ val: count() })
  .from(RSVPs)
  .where(eq(RSVPs.meetupId, id));

const rsvpCount = rsvpResult?.val ?? 0;
const spots = spotsLeft(meetup.capacity, rsvpCount);
const isFull = spots === 0;

const descriptionHtml = renderMarkdown(meetup.description);
---

<BaseLayout
  title={meetup.title}
  description={`Join ${meetup.title} hosted by ${group.name} on ${formatDate(meetup.date)}${meetup.venue ? ` at ${meetup.venue}` : ""}${meetup.city ? `, ${meetup.city}` : ""}. RSVP to secure your spot.`}
>
  <section class="event-page">
    <div class="container">

      <div class="event-header">
        <div class="breadcrumb">
          <a href={withBase("/groups")}>Groups</a>
          <span aria-hidden="true">→</span>
          <a href={groupUrl(group)}>{group.name}</a>
        </div>
        <h1 class="event-title">{meetup.title}</h1>
        {meetup.eventContext && <p class="event-context">{meetup.eventContext}</p>}
      </div>

      <div class="event-layout">

        <!-- Left: event content -->
        <div class="event-content">
          <div class="event-description" set:html={descriptionHtml} />

          {speakers.length > 0 && (
            <section class="pub-section">
              <h2 class="pub-heading">Speakers</h2>
              <div class="pub-speakers-list">
                {speakers.map((s) => (
                  <div class="pub-speaker-card">
                    {s.speakerImageUrl ? (
                      <img src={s.speakerImageUrl} alt={s.speakerName} class="pub-speaker-photo" width={64} height={64} loading="lazy" />
                    ) : (
                      <div class="pub-speaker-placeholder" aria-hidden="true">{s.speakerName.charAt(0).toUpperCase()}</div>
                    )}
                    <div class="pub-speaker-info">
                      <span class="pub-speaker-name">{s.speakerName}</span>
                      {(s.speakerJobTitle || s.speakerCompany) && (
                        <span class="pub-speaker-role">{[s.speakerJobTitle, s.speakerCompany].filter(Boolean).join(" · ")}</span>
                      )}
                      {s.speakerBio && <p class="pub-speaker-bio">{s.speakerBio}</p>}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          {sessions.length > 0 && (
            <section class="pub-section">
              <h2 class="pub-heading">Agenda</h2>
              <div class="pub-sessions-list">
                {sessions.map((s) => (
                  <div class="pub-session-card">
                    <div class="pub-session-header">
                      {s.startTime && (
                        <span class="pub-session-time">
                          {(() => {
                            const [h, m] = s.startTime.split(":").map(Number);
                            const ampm = h >= 12 ? "PM" : "AM";
                            const hour = h % 12 || 12;
                            return `${hour}:${String(m).padStart(2, "0")} ${ampm}`;
                          })()}
                        </span>
                      )}
                      <span class="pub-session-title">{s.title}</span>
                    </div>
                    {s.abstract && <p class="pub-session-abstract">{s.abstract}</p>}
                    {s.speakers.length > 0 && (
                      <div class="pub-session-speakers">
                        {s.speakers.map((sp) => sp && (
                          <div class="pub-session-speaker">
                            {sp.speakerImageUrl ? (
                              <img src={sp.speakerImageUrl} alt={sp.speakerName} class="pub-session-avatar" width={28} height={28} loading="lazy" />
                            ) : (
                              <div class="pub-session-avatar-placeholder" aria-hidden="true">{sp.speakerName.charAt(0)}</div>
                            )}
                            <span class="pub-session-speaker-name">{sp.speakerName}</span>
                            {(sp.speakerJobTitle || sp.speakerCompany) && (
                              <span class="pub-session-speaker-meta">{[sp.speakerJobTitle, sp.speakerCompany].filter(Boolean).join(" · ")}</span>
                            )}
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- Right: action sidebar -->
        <aside class="event-action">
          <!-- Event details -->
          <div class="event-details-card">
            <div class="meetup-detail-row">
              <span class="detail-icon">📅</span>
              <span>{formatDate(meetup.date)}</span>
            </div>
            <div class="meetup-detail-row">
              <span class="detail-icon">🕐</span>
              <span>{formatTime(meetup.time)}</span>
            </div>
            <div class="meetup-detail-row">
              <span class="detail-icon">📍</span>
              <div>
                <a href={osmUrl(meetup.venue, meetup.address)} class="venue-link" target="_blank" rel="noopener noreferrer">
                  {meetup.venue}
                </a>
                {meetup.address && <div class="address">{meetup.address}</div>}
              </div>
            </div>
            {!isFull && !isMeetupCanceled && !isGroupClosed && (
              <div class="meetup-detail-row">
                <span class="detail-icon">👥</span>
                <span class:list={[{ "spots-low": spots <= 5 }]}>
                  {spots} spot{spots === 1 ? "" : "s"} left
                </span>
              </div>
            )}
            <div class="hosted-by">
              <span class="hosted-label">Hosted by</span>
              <a href={groupUrl(group)} class="hosted-group">{group.name}</a>
            </div>
          </div>

          <!-- RSVP action area -->
          <div class="rsvp-action-box">
            {result?.type === "success" ? (
              <div class="success-state">
                <div class="success-icon" aria-hidden="true">🎉</div>
                <h2>You're in!</h2>
                <p>We've got your RSVP. See you there!</p>
                <p class="success-email">Confirmed for <strong>{result.email}</strong>.</p>

                <div class="calendar-section">
                  <p class="calendar-label">Add to your calendar:</p>
                  <div class="calendar-btns">
                    <a href={gcalUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M19 3h-1V1h-2v2H8V1H6v2H5C3.89 3 3 3.9 3 5v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                      </svg>
                      Google Calendar
                    </a>
                    <a href={icsUrl} download class="btn btn-ghost btn-sm">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                      </svg>
                      Download .ics
                    </a>
                  </div>
                  <div class="bsky-share">
                    <a href={bskyShareUrl} target="_blank" rel="noopener noreferrer" class="btn btn-bsky">
                      <svg width="14" height="14" viewBox="0 0 360 320" fill="currentColor" aria-hidden="true">
                        <path d="M180 142c-16.3-31.7-60.7-90.8-102-120C38 2 15.3 1 7.5 1 1 1 0 8.3 0 14.8v11.3c0 27.3 14.7 96.2 62.3 119.4C99.3 163.8 148.7 164 180 164c31.3 0 80.7-.2 117.7-18.5C345.3 122.3 360 53.4 360 26.1V14.8C360 8.3 359 1 352.5 1c-7.8 0-30.5 1-70.5 21C240.7 51.2 196.3 110.3 180 142z"/>
                        <path d="M180 178c-16.3 31.7-60.7 90.8-102 120-40 20-62.7 21-70.5 21C1 319 0 311.7 0 305.2v-11.3c0-27.3 14.7-96.2 62.3-119.4C99.3 156.2 148.7 156 180 156c31.3 0 80.7.2 117.7 18.5C345.3 197.7 360 266.6 360 293.9v11.3c0 6.5-1 13.8-7.5 13.8-7.8 0-30.5-1-70.5-21-41.3-29.2-85.7-88.3-102-120z"/>
                      </svg>
                      Share on Bluesky
                    </a>
                  </div>
                </div>

                <div class="cancel-link-section">
                  <p class="cancel-link-label">Need to cancel? Save this link:</p>
                  <div class="cancel-link-box">
                    <code class="cancel-link-url">{absoluteUrl(Astro.url.origin, `/gatherings/${id}/cancel/${result.cancelToken}`)}</code>
                    <a href={withBase(`/gatherings/${id}/cancel/${result.cancelToken}`)} class="btn btn-ghost btn-sm">Cancel RSVP</a>
                  </div>
                  <p class="cancel-link-hint">Bookmark this or copy it somewhere safe.</p>
                </div>

                <a href={groupUrl(group)} class="back-link-success">← Back to {group.name}</a>
              </div>
            ) : (
              <>
                {result?.type === "duplicate" && (
                  <div class="alert alert-info" role="alert">
                    <strong>Already registered!</strong> <strong>{result.email}</strong> is already on the list. See you there!
                    <p class="duplicate-cancel-hint">
                      <a href={withBase(`/gatherings/${id}/cancel`)}>Need to cancel? →</a>
                    </p>
                  </div>
                )}

                {isGroupClosed ? (
                  <div class="alert alert-warning" role="alert">
                    <strong>{group.name} is no longer active.</strong> RSVPs are closed.
                  </div>
                ) : isMeetupCanceled ? (
                  <div class="alert alert-error" role="alert">
                    <strong>This gathering has been cancelled.</strong> Check the <a href={groupUrl(group)}>{group.name}</a> page for upcoming events.
                  </div>
                ) : isFull ? (
                  <div class="alert alert-error" role="alert">
                    <strong>This gathering is full.</strong> Check back in case a spot opens up.
                  </div>
                ) : (
                  <>
                    <h2 class="rsvp-cta-heading">Count me in!</h2>
                    <form method="POST" class="rsvp-form" novalidate>
                      <input name="_hp" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp-field" />
                      <input name="_t" type="hidden" value={String(Date.now())} />

                      {result?.type === "error" && (
                        <div class="alert alert-error" role="alert">{result.message}</div>
                      )}
                      {spots <= 5 && (
                        <div class="alert alert-warning">Only <strong>{spots}</strong> spot{spots === 1 ? "" : "s"} left!</div>
                      )}

                      <div class="form-group">
                        <label for="name">Your name *</label>
                        <input id="name" name="name" type="text" placeholder="Taylor Kim" required />
                      </div>
                      <div class="form-group">
                        <label for="email">Email address *</label>
                        <input id="email" name="email" type="email" placeholder="taylor@example.com" required />
                        <span class="form-hint">Only used to manage your attendance.</span>
                      </div>
                      <div class="form-group">
                        <label for="jobTitle">Job title *</label>
                        <input id="jobTitle" name="jobTitle" type="text" placeholder="Developer Advocate…" required />
                      </div>
                      <div class="form-group">
                        <label for="company">Company *</label>
                        <input id="company" name="company" type="text" placeholder="Acme Corp" required />
                      </div>

                      <p class="privacy-notice">
                        Your info is shared with <strong>{group.name}</strong> for attendance management only. <a href={withBase("/privacy")}>Privacy policy →</a>
                      </p>

                      <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        Count me in! →
                      </button>
                    </form>

                    {!isPast && (
                      <p class="cancel-note">
                        Already registered? <a href={withBase(`/gatherings/${id}/cancel`)}>Cancel your RSVP</a>
                      </p>
                    )}
                  </>
                )}
              </>
            )}
          </div>

          <p class="rsvp-note">No account needed.</p>
        </aside>

      </div><!-- end .event-layout -->
    </div><!-- end .container -->
  </section>
</BaseLayout>

<style>
  /* ── Page shell ── */
  .event-page { padding: 2.5rem 0 5rem; }

  .event-header {
    margin-bottom: 2rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { text-decoration: none; font-weight: 600; color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-primary); }

  .event-title {
    font-size: var(--size-4xl);
    line-height: 1.15;
    margin-bottom: 0.375rem;
  }

  .event-context {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  /* ── Two-column layout ── */
  .event-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Left: content ── */
  .event-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  /* Description prose */
  .event-description {
    font-size: var(--size-base);
    line-height: 1.7;
    color: var(--color-text);
  }
  .event-description :global(p) { margin: 0 0 1em; max-width: 68ch; }
  .event-description :global(h2),
  .event-description :global(h3) { margin: 1.5em 0 0.5em; font-size: var(--size-lg); }
  .event-description :global(ul),
  .event-description :global(ol) { padding-left: 1.5rem; margin: 0 0 1em; }
  .event-description :global(li) { margin-bottom: 0.25em; }
  .event-description :global(a) { color: var(--color-primary); }
  .event-description :global(strong) { font-weight: 700; }

  /* Speakers & Agenda sections */
  .pub-section {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 2px dashed var(--color-border);
  }
  .pub-heading { font-size: var(--size-xl); margin-bottom: 1.25rem; }

  /* Speakers */
  .pub-speakers-list { display: flex; flex-direction: column; gap: 1.25rem; }
  .pub-speaker-card { display: flex; gap: 1rem; align-items: flex-start; }
  .pub-speaker-photo { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 2px solid var(--color-border); flex-shrink: 0; }
  .pub-speaker-placeholder { width: 64px; height: 64px; border-radius: 50%; background: var(--color-primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: 700; font-family: var(--font-display); flex-shrink: 0; }
  .pub-speaker-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.125rem; }
  .pub-speaker-name { font-weight: 700; font-size: var(--size-base); }
  .pub-speaker-role { font-size: var(--size-sm); color: var(--color-text-muted); }
  .pub-speaker-bio { font-size: var(--size-xs); color: var(--color-text-muted); line-height: 1.5; margin: 0.375rem 0 0; max-width: none; padding-top: 0.375rem; border-top: 1px solid var(--color-border); }

  /* Agenda */
  .pub-sessions-list { display: flex; flex-direction: column; gap: 0.875rem; }
  .pub-session-card { background: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.125rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .pub-session-header { display: flex; align-items: baseline; gap: 0.625rem; flex-wrap: wrap; }
  .pub-session-time { font-size: var(--size-xs); font-weight: 700; color: var(--color-primary); white-space: nowrap; }
  .pub-session-title { font-weight: 700; font-size: var(--size-base); }
  .pub-session-abstract { font-size: var(--size-sm); color: var(--color-text-muted); line-height: 1.5; margin: 0; max-width: none; }
  .pub-session-speakers { display: flex; flex-direction: column; gap: 0.375rem; padding-top: 0.5rem; border-top: 1px dashed var(--color-border); }
  .pub-session-speaker { display: flex; align-items: center; gap: 0.5rem; }
  .pub-session-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--color-border); flex-shrink: 0; }
  .pub-session-avatar-placeholder { width: 28px; height: 28px; border-radius: 50%; background: var(--color-primary); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; flex-shrink: 0; }
  .pub-session-speaker-name { font-weight: 600; font-size: var(--size-sm); }
  .pub-session-speaker-meta { font-size: var(--size-xs); color: var(--color-text-muted); }

  /* ── Right: action sidebar ── */
  .event-action {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .event-details-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.125rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meetup-detail-row {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    font-size: var(--size-sm);
  }
  .detail-icon { flex-shrink: 0; }
  .spots-low { color: #b45309; font-weight: 700; }

  .venue-link { color: inherit; font-weight: 600; text-decoration: underline; text-decoration-style: dotted; text-underline-offset: 2px; }
  .venue-link:hover { color: var(--color-primary); text-decoration-style: solid; }
  .address { color: var(--color-text-muted); font-size: var(--size-xs); margin-top: 0.125rem; }

